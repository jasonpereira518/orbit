# Database — leave empty to use local PGlite (.data/pglite)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Clerk (optional in development — demo mode uses demo-user; required in production)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# AI providers — optional server-side keys; users can also add BYOK in Settings
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Encrypts user-provided API keys at rest
ENCRYPTION_SECRET=change-me-to-a-long-random-string
