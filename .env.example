# Database — leave empty to use local PGlite (.data/pglite)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Clerk (optional — without these, app runs in demo mode as demo-user)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# OpenAI — optional server-side key; users can also add BYOK in Settings
# OPENAI_API_KEY=sk-...

# Encrypts user-provided API keys at rest
ENCRYPTION_SECRET=change-me-to-a-long-random-string
